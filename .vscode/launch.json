{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug current Python file",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Debug FastAPI app",
      "type": "debugpy",
      "request": "launch",
      "module": "fastapi",
      "args": ["dev", "main.py"],
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
